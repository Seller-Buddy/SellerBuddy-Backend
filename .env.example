# Copy the required values into .env. Never commit real API credentials.
UPSTAGE_API_KEY=
UPSTAGE_EMBEDDING_QUERY_MODEL=embedding-query
UPSTAGE_EMBEDDING_PASSAGE_MODEL=embedding-passage
SERPER_API_KEY=
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# Comma-separated frontend origins, without a trailing slash.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
BACKEND_PORT=8000
LOG_LEVEL=INFO
SHOPBUDDY_VERSION=local
